# ===========================
# 1. System Files (Keep repo clean for Windows/Linux users)
# ===========================
.DS_Store
.AppleDouble
.LSOverride

# ===========================
# 2. Python Cache & Build Artifacts
# ===========================
__pycache__/
*.pyc
*.pyo
build/
dist/
*.egg-info/

# ===========================
# 3. Jupyter Notebook Checkpoints
# ===========================
.ipynb_checkpoints/

# ===========================
# 4. [CRITICAL] Data Security & Privacy (CBS Compliance)
# ===========================
# Ignore specific large or sensitive file types everywhere
*.csv
*.xlsx
*.xls
*.irs
*.pdf
*.h5

# Ignore all data directory contents to prevent leakage but not the first sub folder
data/
!data/*/
# Exception: Keep the README to maintain folder structure
!data/README.md
# Exception: Keep dummy data/demos for reproducibility 
!data/dummy/
!data/dummy/**
# Exception: make the subfile push-able
!data/**/.gitkeep


# ===========================
# 5. Environment Variables & Secrets
# ===========================
.env
.venv
env/
venv/
