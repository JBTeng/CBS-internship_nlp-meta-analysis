# ===========================
# 1. System Files
# ===========================
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# ===========================
# 2. Python Cache & Build Artifacts
# ===========================
__pycache__/
*.py[cod]
*$py.class
build/
dist/
*.egg-info/
.venv/
venv/
env/

# ===========================
# 3. Jupyter & Quarto (Critical for Phase 4)
# ===========================
.ipynb_checkpoints/
.quarto/
_site/
*_files/
*.html
*.pdf
*.docx

# ===========================
# 4. R Specific
# ===========================
.Rhistory
.RData
.Ruserdata
.Rproj.user/

# ===========================
# 5. [CRITICAL] Data Security (CBS Compliance)
# ===========================
# Global ignore for data types
*.csv
*.xlsx
*.xls
*.irs
*.ris
*.enw
*.bib
*.txt
*.h5

# Ignore all data directory contents
data/*
!data/*/

# Exceptions: Keep Documentation & Demos
!data/README.md
!data/dummy/
!data/dummy/**
!data/**/.gitkeep

# ===========================
# 6. Secrets
# ===========================
.env
